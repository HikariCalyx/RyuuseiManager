<Window x:Class="RyuuseiManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RyuuseiManager"
        mc:Ignorable="d"
        Title="{DynamicResource Dlg_Settings}" Height="400" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <!-- Header row: Label + ComboBox -->
            <RowDefinition Height="*"/>
            <!-- Rest of the settings area -->
        </Grid.RowDefinitions>

        <!-- Top 30 DIP row -->
        <Grid Grid.Row="0" Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="{DynamicResource Msg_Language}"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="0,0,8,0"/>

            <ComboBox x:Name="ComboLanguageList" Grid.Column="1"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Text"
                      SelectedValuePath="Value"
                      Margin="4"
                      FontSize="14"
                      SelectionChanged="ComboLanguageList_SelectionChanged"/>
        </Grid>
        <Grid Grid.Row="1" Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="{DynamicResource SteamPath}"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="0,0,8,0"/>

            <ComboBox x:Name="ComboSteamPath" Grid.Column="1"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Text"
                      SelectedValuePath="Value"
                      Margin="4"
                      FontSize="14"
                      SelectionChanged="ComboSteamPath_SelectionChanged"/>
        </Grid>

        <Border Grid.Row="2"
                Margin="8"
                Background="#FFF5F5F5"
                CornerRadius="4"
                BorderBrush="#FFCCCCCC"
                BorderThickness="1">
            <TextBlock x:Name="VersionText"
                       Text="Version"
                       FontSize="14"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       Margin="8"/>
        </Border>

    </Grid>
</Window>
