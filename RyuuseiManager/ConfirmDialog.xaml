<Window x:Class="RyuuseiManager.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="title"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="500"
        Padding="15">

    <Grid RowDefinitions="Auto,Auto,Auto" Margin="0">

        <!-- Prompt text -->
        <TextBlock x:Name="PromptText" Text="PromptMessage" 
                   FontSize="14"
                   Margin="10,10,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right" Height="30"
                    Margin="10">

            <Button Content="{DynamicResource Btn_Yes}"
                    Width="80" Height="26" FontSize="15"
                    IsDefault="True"
                    Click="Ok_Click"
                    Margin="2"/>

            <Button Content="{DynamicResource Btn_No}"
                    Width="80" Height="26" FontSize="15"
                    IsCancel="True"
                    Margin="2"/>
        </StackPanel>

    </Grid>
</Window>
