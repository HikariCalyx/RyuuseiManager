<Page x:Class="RyuuseiManager.CoverTabPageSF3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RyuuseiManager"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CoverTabPageSF3">

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" x:Name="ProfileRow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="4">
                    <Image x:Name="Mugshot"
                           Width="40"
                           Height="48"
                           Stretch="UniformToFill"
                           Source="{Binding ImageSourceMugshot, RelativeSource={RelativeSource AncestorType=Page}}"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="{Binding ScalingType, RelativeSource={RelativeSource AncestorType=Page}}"/>

                </Grid>


                <Grid Grid.Column="1">
                    <StackPanel Grid.Column="1"
        Orientation="Vertical" VerticalAlignment="Center">
                        <TextBox x:Name="NoiseForm"
                                 Height="25"
                                 Margin="0,0,4,4"
                                 FontSize="20"
                                 FontWeight="Bold"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"/>

                        <TextBox x:Name="Message"
                                 Height="20"
                                 Margin="0,0,4,0"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid> <!-- Personal -->
            <Grid Grid.Row="2" Background="#FF309AD3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="4">
                    <Image x:Name="TeamIcon"
                           Width="50"
                           Height="54"
                           Stretch="UniformToFill"
                           Source="{Binding ImageSourceTeamIcon, RelativeSource={RelativeSource AncestorType=Page}}"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="{Binding ScalingType, RelativeSource={RelativeSource AncestorType=Page}}"/>
                </Grid>

                <Grid Grid.Column="1">
                    <StackPanel Grid.Column="1"
        Orientation="Vertical" VerticalAlignment="Center">
                        <TextBox x:Name="TeamName"
                                 Height="25"
                                 Margin="0,0,4,4"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"/>

                        <TextBox x:Name="TeamPurpose"
                                 Height="20"
                                 Margin="0,0,4,0"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="4" Background="White">
                
            </Grid>
            <!-- Team -->
        </Grid>

        <Grid Grid.Column="1" Margin="8,0,8,0" Background="#FFE7720D">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Image Source="/GameResource;component/Resources/Ability/AbilityIcon.png" Width="14" Height="14" SnapsToDevicePixels="True" 
                                           RenderOptions.BitmapScalingMode="NearestNeighbor" Margin="4,0,0,0"></Image>
                </Grid>
                <Grid Grid.Column="1">
                    <Label Content="{DynamicResource Cover_Abilities}" FontSize="13" Foreground="#FFFFD640" FontWeight="Heavy" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
            <Grid Grid.Row="1">
                <ListBox x:Name="AbilityList" 
                         HorizontalContentAlignment="Stretch"
                         Background="#FFE7720D"
                         BorderBrush="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="#FFB45929"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="IsSelected" Value="False"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFB45929"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0" SnapsToDevicePixels="True" UseLayoutRounding="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Label}"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FFD6F6C6"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="8,0,0,0"
                                           FontSize="20"
                                           Foreground="White"
                                           Text="{Binding Quantity}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Label Content="{DynamicResource Cover_Total}" FontSize="13" Foreground="#FFFFD640" FontWeight="Heavy" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Column="1">
                    <Label x:Name="TotalCost" Content="0" FontSize="13" Foreground="White" FontWeight="Heavy" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>


</Page>
