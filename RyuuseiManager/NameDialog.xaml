<Window x:Class="RyuuseiManager.NameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="title"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="350"
        Padding="15">

    <Grid RowDefinitions="Auto,Auto,Auto" Margin="0">

        <!-- Prompt text -->
        <TextBlock x:Name="PromptText" Text="PromptMessage" 
                   FontSize="14"
                   Margin="10,10,0,10"/>

        <!-- Text input -->
        <TextBox x:Name="InputBox"
                 Grid.Row="1"
                 MinWidth="300" Height="26" FontSize="15"
                 VerticalAlignment="Center"
                 Margin="10,10,10,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right" Height="30"
                    Margin="10">

            <Button Content="OK"
                    Width="80" Height="26" FontSize="15"
                    IsDefault="True"
                    Click="Ok_Click"
                    Margin="2"/>

            <Button Content="Cancel"
                    Width="80" Height="26" FontSize="15"
                    IsCancel="True"
                    Margin="2"/>
        </StackPanel>

    </Grid>
</Window>
